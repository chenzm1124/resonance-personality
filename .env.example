# 共鸣人格IP打造系统 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# ========== 后端配置 ==========
APP_NAME=共鸣人格IP打造系统
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库
DATABASE_URL=sqlite:///./resonance_personality.db

# 微信小程序
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# JWT (用于内部鉴权，MVP阶段可选)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== 前端配置 ==========
# API地址 (写入 miniprogram/.env)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ========== V1.1 微信支付 ==========
# WECHAT_MCH_ID=
# WECHAT_MCH_KEY=
# WECHAT_NOTIFY_URL=
