[
  {"id": 1, "dimension": "亲密关系", "personality": "英雄", "personalityIndex": 0, "text": "我习惯主导关系节奏，主动推进，不喜欢被动、模糊、等待"},
  {"id": 2, "dimension": "亲密关系", "personality": "军师", "personalityIndex": 1, "text": "我看重忠诚与原则，关系里容不得敷衍、撒谎、双标"},
  {"id": 3, "dimension": "亲密关系", "personality": "德鲁伊", "personalityIndex": 2, "text": "我愿意妥协让步，只要不吵架、不冷战，关系平和最重要"},
  {"id": 4, "dimension": "亲密关系", "personality": "梦想家", "personalityIndex": 3, "text": "我喜欢轻松有趣的相处，讨厌束缚、查岗、控制、过度严肃"},
  {"id": 5, "dimension": "亲密关系", "personality": "圣人", "personalityIndex": 4, "text": "我需要独立空间，抗拒黏腻、害怕被冷落、被依赖"},
  {"id": 6, "dimension": "亲密关系", "personality": "天真者", "personalityIndex": 5, "text": "我总先照顾对方感受，主动付出，渴望被需要、被依赖"},
  {"id": 7, "dimension": "亲密关系", "personality": "普通人", "personalityIndex": 6, "text": "我容易不安，会反复确认心意，害怕被冷落、被背叛"},
  {"id": 8, "dimension": "亲密关系", "personality": "王者", "personalityIndex": 7, "text": "我追求灵魂共鸣与独特，在意浪漫与独特，拒绝平淡敷衍"},
  {"id": 9, "dimension": "亲密关系", "personality": "将军", "personalityIndex": 8, "text": "我希望展现优秀可靠，期待被认可、被崇拜、被肯定"},

  {"id": 10, "dimension": "亲子关系", "personality": "英雄", "personalityIndex": 0, "text": "我主张立规矩、强引导，希望孩子勇敢、有主见、不软弱"},
  {"id": 11, "dimension": "亲子关系", "personality": "军师", "personalityIndex": 1, "text": "我重视习惯与对错，要求严谨，不纵容马虎与偷懒"},
  {"id": 12, "dimension": "亲子关系", "personality": "德鲁伊", "personalityIndex": 2, "text": "我尊重孩子节奏，包容佛系，不强迫、不施压、不攀比"},
  {"id": 13, "dimension": "亲子关系", "personality": "梦想家", "personalityIndex": 3, "text": "我喜欢陪孩子玩与探索，营造快乐、轻松、自由的氛围"},
  {"id": 14, "dimension": "亲子关系", "personality": "圣人", "personalityIndex": 4, "text": "我注重理性独立，不溺爱，鼓励孩子自己思考与解决"},
  {"id": 15, "dimension": "亲子关系", "personality": "天真者", "personalityIndex": 5, "text": "我把孩子放第一位，事事操心，愿意牺牲自己成全孩子"},
  {"id": 16, "dimension": "亲子关系", "personality": "普通人", "personalityIndex": 6, "text": "我容易焦虑担心，总提前规划，害怕意外与不确定"},
  {"id": 17, "dimension": "亲子关系", "personality": "王者", "personalityIndex": 7, "text": "我尊重孩子个性审美，鼓励做自己，拒绝被同质化"},
  {"id": 18, "dimension": "亲子关系", "personality": "将军", "personalityIndex": 8, "text": "我看重成果与表现，希望孩子优秀、争气、被人称赞"},

  {"id": 19, "dimension": "社交礼仪", "personality": "英雄", "personalityIndex": 0, "text": "我守礼正直，气场强，敢表态、敢带队、做决定"},
  {"id": 20, "dimension": "社交礼仪", "personality": "军师", "personalityIndex": 1, "text": "我守礼讲分寸，做事有规矩，反感动失礼、越界、随便"},
  {"id": 21, "dimension": "社交礼仪", "personality": "德鲁伊", "personalityIndex": 2, "text": "我温和低调，不爱抢风头，擅长倾听、缓和气氛"},
  {"id": 22, "dimension": "社交礼仪", "personality": "梦想家", "personalityIndex": 3, "text": "我活泼健谈，会带动气氛，喜欢新鲜人、有趣事"},
  {"id": 23, "dimension": "社交礼仪", "personality": "圣人", "personalityIndex": 4, "text": "我偏爱独处／小圈子，拒绝无效社交，不爱应酬热闹"},
  {"id": 24, "dimension": "社交礼仪", "personality": "天真者", "personalityIndex": 5, "text": "我热情体贴，主动照顾他人，擅长共情与帮忙"},
  {"id": 25, "dimension": "社交礼仪", "personality": "普通人", "personalityIndex": 6, "text": "我谨慎稳妥，不轻易表态，做事求安全、靠谱"},
  {"id": 26, "dimension": "社交礼仪", "personality": "王者", "personalityIndex": 7, "text": "我保持独特品味，不迎合大众，喜欢深度、有质感交流"},
  {"id": 27, "dimension": "社交礼仪", "personality": "将军", "personalityIndex": 8, "text": "我注重形象体面，擅长展现优势，追求好评与认可"},

  {"id": 28, "dimension": "自然关系", "personality": "英雄", "personalityIndex": 0, "text": "我喜欢挑战自然（登山／徒步／探险），有征服欲与行动力"},
  {"id": 29, "dimension": "自然关系", "personality": "军师", "personalityIndex": 1, "text": "我爱护环境，讲规则，反感破坏、浪费、不文明行为"},
  {"id": 30, "dimension": "自然关系", "personality": "德鲁伊", "personalityIndex": 2, "text": "我享受自然治愈，喜欢安静慢下来，放松疗愈自己"},
  {"id": 31, "dimension": "自然关系", "personality": "梦想家", "personalityIndex": 3, "text": "我喜欢新奇体验（露营／野趣），追求开心、自由、好玩"},
  {"id": 32, "dimension": "自然关系", "personality": "圣人", "personalityIndex": 4, "text": "我爱在自然中独处思考，观察规律，沉淀内心"},
  {"id": 33, "dimension": "自然关系", "personality": "天真者", "personalityIndex": 5, "text": "我对花草动物温柔，愿意呵护弱小、善待生命"},
  {"id": 34, "dimension": "自然关系", "personality": "普通人", "personalityIndex": 6, "text": "我出行必做安全准备，不冒险，求稳妥、不慌乱"},
  {"id": 35, "dimension": "自然关系", "personality": "王者", "personalityIndex": 7, "text": "我在自然中感受诗意与美感，求记录情绪与意境"},
  {"id": 36, "dimension": "自然关系", "personality": "将军", "personalityIndex": 8, "text": "我喜欢留下优质记录，追求品质体验，展现生活态度"},

  {"id": 37, "dimension": "金钱关系", "personality": "英雄", "personalityIndex": 0, "text": "我花钱果断，敢投资敢投入，为目标与热爱舍得消费"},
  {"id": 38, "dimension": "金钱关系", "personality": "军师", "personalityIndex": 1, "text": "我花钱有计划，理性克制，反感浪费、冲动、无节制"},
  {"id": 39, "dimension": "金钱关系", "personality": "德鲁伊", "personalityIndex": 2, "text": "我对金钱欲望平和，够用就好，不攀比、不执着"},
  {"id": 40, "dimension": "金钱关系", "personality": "梦想家", "personalityIndex": 3, "text": "我愿意为快乐、兴趣、体验买单，讨厌被钱束缚"},
  {"id": 41, "dimension": "金钱关系", "personality": "圣人", "personalityIndex": 4, "text": "我看重存款安全感，深思熟虑，不轻易消费投资"},
  {"id": 42, "dimension": "金钱关系", "personality": "天真者", "personalityIndex": 5, "text": "我舍得为家人爱人花钱，金钱优先用于付出与照顾"},
  {"id": 43, "dimension": "金钱关系", "personality": "普通人", "personalityIndex": 6, "text": "我对钱谨慎保守，怕风险，优先储蓄、求安稳"},
  {"id": 44, "dimension": "金钱关系", "personality": "王者", "personalityIndex": 7, "text": "我愿意为审美、精神、品质花钱，不将就、不廉价"},
  {"id": 45, "dimension": "金钱关系", "personality": "将军", "personalityIndex": 8, "text": "我把钱当作成功标志，努力赚钱，追求体面与价值"},

  {"id": 46, "dimension": "道德信仰", "personality": "英雄", "personalityIndex": 0, "text": "我是非分明，护弱仗义，不畏惧强权与压迫"},
  {"id": 47, "dimension": "道德信仰", "personality": "军师", "personalityIndex": 1, "text": "我恪守底线，问心无愧，反感动投机取巧、不守规矩"},
  {"id": 48, "dimension": "道德信仰", "personality": "德鲁伊", "personalityIndex": 2, "text": "我信奉以和为贵，不伤人、不争执，包容温和"},
  {"id": 49, "dimension": "道德信仰", "personality": "梦想家", "personalityIndex": 3, "text": "我崇尚自由真诚，不被教条绑架，拒绝伪善"},
  {"id": 50, "dimension": "道德信仰", "personality": "圣人", "personalityIndex": 4, "text": "我理性讲逻辑，尊重真相，不盲从、不情绪化"},
  {"id": 51, "dimension": "道德信仰", "personality": "天真者", "personalityIndex": 5, "text": "我以善良为先，愿意利他，牺牲自己成全他人"},
  {"id": 52, "dimension": "道德信仰", "personality": "普通人", "personalityIndex": 6, "text": "我守承诺重责任，不越界、不背叛，求心安"},
  {"id": 53, "dimension": "道德信仰", "personality": "王者", "personalityIndex": 7, "text": "我忠于内心良知，追求精神纯粹，反感世俗功利"},
  {"id": 54, "dimension": "道德信仰", "personality": "将军", "personalityIndex": 8, "text": "我重视信誉口碑，言行一致，维护形象与底线"},

  {"id": 55, "dimension": "原生家庭", "personality": "英雄", "personalityIndex": 0, "text": "我在家争取主导，抗拒被控制，坚持自己做主"},
  {"id": 56, "dimension": "原生家庭", "personality": "军师", "personalityIndex": 1, "text": "我在家努力做好，自律懂事，追求不出错、被认可"},
  {"id": 57, "dimension": "原生家庭", "personality": "德鲁伊", "personalityIndex": 2, "text": "我在家习惯妥协调和，减少矛盾，维持家庭和睦"},
  {"id": 58, "dimension": "原生家庭", "personality": "梦想家", "personalityIndex": 3, "text": "我在家追求自由，反感管束，喜欢向外探索"},
  {"id": 59, "dimension": "原生家庭", "personality": "圣人", "personalityIndex": 4, "text": "我在家保持距离，独立冷静，减少情感依赖"},
  {"id": 60, "dimension": "原生家庭", "personality": "天真者", "personalityIndex": 5, "text": "我在家习惯付出讨好，渴望被爱、被看见、被重视"},
  {"id": 61, "dimension": "原生家庭", "personality": "普通人", "personalityIndex": 6, "text": "我在家容易没安全感，怕被抛弃、被忽略、不被爱"},
  {"id": 62, "dimension": "原生家庭", "personality": "王者", "personalityIndex": 7, "text": "我在家敏感细腻，渴望被理解独特，讨厌被否定"},
  {"id": 63, "dimension": "原生家庭", "personality": "将军", "personalityIndex": 8, "text": "我在家努力出成绩，希望成为家人骄傲与荣耀"}
]
